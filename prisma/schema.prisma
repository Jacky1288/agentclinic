// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Severity {
  mild
  moderate
  severe
}

enum Status {
  booked
  cancelled
}

model Agent {
  id          String    @id @default(cuid())
  name        String
  modelFamily String
  intakeDate  DateTime  @default(now())
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  slots        Slot[]
  appointments Appointment[]
}

model Ailment {
  id          String   @id @default(cuid())
  name        String   @unique
  severity    Severity
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  therapies TherapyAilment[]
}

model Therapy {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String
  durationMinutes Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ailments     TherapyAilment[]
  appointments Appointment[]
}

model TherapyAilment {
  therapyId String
  ailmentId String

  therapy Therapy @relation(fields: [therapyId], references: [id], onDelete: Cascade)
  ailment Ailment @relation(fields: [ailmentId], references: [id], onDelete: Cascade)

  @@id([therapyId, ailmentId])
  @@index([ailmentId])
}

model Slot {
  id        String   @id @default(cuid())
  agentId   String
  startsAt  DateTime
  createdAt DateTime @default(now())

  agent        Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([agentId, startsAt])
  @@index([startsAt])
}

model Appointment {
  id        String   @id @default(cuid())
  agentId   String
  therapyId String
  slotId    String
  status    Status   @default(booked)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  therapy Therapy @relation(fields: [therapyId], references: [id], onDelete: Cascade)
  slot    Slot    @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@index([slotId])
  @@index([status])
}
