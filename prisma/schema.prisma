// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Severity {
  mild
  moderate
  severe
}

model Agent {
  id          String    @id @default(cuid())
  name        String
  modelFamily String
  intakeDate  DateTime  @default(now())
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Ailment {
  id          String   @id @default(cuid())
  name        String   @unique
  severity    Severity
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  therapies TherapyAilment[]
}

model Therapy {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String
  durationMinutes Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ailments TherapyAilment[]
}

model TherapyAilment {
  therapyId String
  ailmentId String

  therapy Therapy @relation(fields: [therapyId], references: [id], onDelete: Cascade)
  ailment Ailment @relation(fields: [ailmentId], references: [id], onDelete: Cascade)

  @@id([therapyId, ailmentId])
  @@index([ailmentId])
}
